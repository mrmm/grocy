{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Node",
		"strict": true,
		"jsx": "preserve",
		"sourceMap": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"lib": [
			"DOM",
			"ES2020"
		],
		"types": [
			"vite/client",
			"node"
		],
		"strictNullChecks": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.vue"
	]
}
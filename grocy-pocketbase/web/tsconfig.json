{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Node",
		"baseUrl": "./",
		"jsx": "preserve",
		"sourceMap": true,
		"lib": [
			"DOM",
			"ES2020"
		],
		"paths": {
			"@/*": [
				"src/*"
			]
		},
		"types": [
			"vite/client",
			"node",
			"vitest"
		],
		"strict": true,
		"noImplicitAny": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.vue",
		"tests"
	]
}